// ==================== دوال الوعي الجغرافي ====================
static float get_algeria_latitude(const char* region) {
    if(strcmp(region, "north") == 0) return 36.8f;
    if(strcmp(region, "highlands") == 0) return 35.5f;
    if(strcmp(region, "sahara") == 0) return 27.0f;
    return 32.0f;
}

static int get_sunset_hour() {
    time_t now; time(&now);
    struct tm* tm = localtime(&now);
    int day = tm->tm_yday;
    float lat = expert_stats.latitude;
    if(lat == 0) lat = ALGERIA_DEFAULT_LATITUDE;
    
    float decl = 23.45f * sin(2 * M_PI * (284 + day) / 365.0f);
    float cos_arg = -tan(lat * M_PI / 180) * tan(decl * M_PI / 180);
    if(cos_arg > 1) cos_arg = 1; if(cos_arg < -1) cos_arg = -1;
    float ha = acos(cos_arg);
    return (int)(12 + ha * 12 / M_PI);
}

static bool is_night_time() {
    time_t now; time(&now);
    struct tm* tm = localtime(&now);
    int sunset = get_sunset_hour();
    return (tm->tm_hour < 6 || tm->tm_hour > sunset);
}

static float get_time_factor() {
    if(is_night_time()) return 0.4f;
    time_t now; time(&now);
    struct tm* tm = localtime(&now);
    int hour = tm->tm_hour;
    
    if(expert_stats.latitude < 30.0f) {
        if(hour >= 7 && hour <= 10) return 1.5f;
        if(hour >= 16 && hour <= 18) return 1.3f;
        if(hour >= 11 && hour <= 15) return 0.4f;
        return 0.8f;
    }
    
    if(hour >= 9 && hour <= 12) return 1.4f;
    if(hour >= 14 && hour <= 17) return 1.2f;
    if(hour >= 12 && hour <= 14) return 0.7f;
    return 1.0f;
}

// ==================== دوال التحليل ====================
static float get_weight_trend() { return weight_history.trend(); }

static float calculate_health_score(const HiveContext& ctx, int hive_id) {
    const auto& th = thresholds[hive_id];
    float score = 100.0f;
    time_t now; time(&now);
    struct tm* tm = localtime(&now);
    int month = tm->tm_mon + 1;
    bool is_summer = (month >= 6 && month <= 8);
    
    if(ctx.temperature_avg > th.temp_warning) {
        if(is_summer && ctx.temperature_avg < th.temp_warning + 3.0f) score -= 10;
        else score -= 20;
    }
    if(ctx.humidity < ALGERIA_HUM_CRITICAL) score -= 15;
    else if(ctx.humidity < ALGERIA_HUM_WARNING) score -= 8;
    if(ctx.gas > th.gas_critical) score -= 30;
    else if(ctx.gas > GAS_WARNING) score -= 15;
    if(ctx.battery < BATTERY_CRITICAL) score -= 30;
    else if(ctx.battery < BATTERY_WARNING) score -= 15;
    
    float trend = get_weight_trend();
    if(trend < -ALGERIA_SWARMING_DROP_RATE) {
        if(is_summer && trend < -0.8f) score -= 25;
        else score -= 25;
    }
    score *= 1.05f;
    if(score < 0) score = 0;
    if(score > 100) score = 100;
    return score;
}

static float predict_swarming_risk(const HiveContext& ctx, int hive_id) {
    const auto& th = thresholds[hive_id];
    float risk = 0;
    float trend = get_weight_trend();
    time_t now; time(&now);
    struct tm* tm = localtime(&now);
    int month = tm->tm_mon + 1;
    bool is_spring = (month >= 3 && month <= 5);
    
    if(trend < -th.weight_drop_rate) risk += 50;
    else if(trend < -0.4f) risk += 25;
    if(ctx.sound > th.sound_swarming) risk += 30;
    else if(ctx.sound > 65) risk += 15;
    if(ctx.motion_entrance && ctx.motion_inside) risk += 20;
    if(is_spring) risk *= 1.3f;
    risk *= get_time_factor();
    return risk > 100 ? 100 : risk;
}

// ==================== دوال النظام السيادي ====================
void set_region(const char* region) {
    strncpy(expert_stats.region, region, sizeof(expert_stats.region)-1);
    expert_stats.latitude = get_algeria_latitude(region);
    ESP_LOGI(TAG, "🌍 تم ضبط المنطقة: %s (خط العرض: %.1f°)", region, expert_stats.latitude);
}

// ==================== دالة التحليل الرئيسية ====================
void analyze(const HiveContext& ctx, int hive_id) {
    if(!running) return;
    
    weight_history.push(ctx.weight);
    temp_history.push(ctx.temperature_avg);
    sound_history.push(ctx.sound);
    vibration_history.push(ctx.vibration);
    
    const auto& th = thresholds[hive_id];
    float swarming_risk = predict_swarming_risk(ctx, hive_id);
    float health_score = calculate_health_score(ctx, hive_id);
    
    AIResult result = AIResult::Healthy;
    
    if(ctx.temperature_avg > th.temp_critical || ctx.gas > th.gas_critical) {
        result = AIResult::Anomaly;
        expert_stats.critical++;
        snprintf(last_result, sizeof(last_result),
                 "⚠️ حرج: حرارة=%.1f°C غاز=%d | %s",
                 ctx.temperature_avg, ctx.gas, expert_stats.region);
    }
    else if(swarming_risk > 70) {
        result = AIResult::Swarming;
        expert_stats.critical++;
        snprintf(last_result, sizeof(last_result),
                 "🚨 خطر تطريد: %.0f%% | انخفاض الوزن=%.2f كجم/ساعة",
                 swarming_risk, get_weight_trend());
    }
    else if(ctx.vibration > th.varroa_vibration) {
        result = AIResult::Varroa;
        expert_stats.warning++;
        snprintf(last_result, sizeof(last_result),
                 "🕷️ فاریوا: اهتزاز=%d | عالج فوراً", ctx.vibration);
    }
    else if(!ctx.motion_entrance && !ctx.motion_inside && !is_night_time()) {
        result = AIResult::QueenLost;
        expert_stats.warning++;
        snprintf(last_result, sizeof(last_result),
                 "👑 فقدان الملكة: لا حركة | %s", expert_stats.region);
    }
    else {
        result = AIResult::Healthy;
        snprintf(last_result, sizeof(last_result),
                 "✅ سليم: نسبة الصحة=%.0f%% | حرارة=%.1f°C | %s",
                 health_score, ctx.temperature_avg, expert_stats.region);
    }
    
    expert_stats.total++;
    
    HiveState new_state;
    switch(result) {
        case AIResult::Swarming:
            new_state = SwarmingState{swarming_risk, time(nullptr), 1};
            break;
        case AIResult::QueenLost:
            new_state = QueenLostState{time(nullptr), 70.0f};
            break;
        case AIResult::Varroa:
            new_state = SickState{SickState::Varroa, 60.0f, 0.75f};
            break;
        case AIResult::Anomaly:
            new_state = CriticalState{CriticalState::Temperature, ctx.temperature_avg, th.temp_critical};
            break;
        default:
            new_state = NormalState{health_score, time(nullptr)};
            break;
    }
    
    if(new_state.index() != current_state.index()) {
        previous_state = current_state;
        current_state = new_state;
        if(state_callback) state_callback(previous_state, current_state);
        ESP_LOGI(TAG, "🎯 الخلية %d: %s → %s", hive_id,
                 stateToString(previous_state), stateToString(current_state));
    }
    
    ESP_LOGI(TAG, "🧠 الخلية %d: %s", hive_id, last_result);
}

// ==================== API العامة ====================
void init(void) {
    weight_history.init();
    temp_history.init();
    sound_history.init();
    vibration_history.init();
    memset(&expert_stats, 0, sizeof(expert_stats));
    expert_stats.latitude = ALGERIA_DEFAULT_LATITUDE;
    strcpy(expert_stats.region, "Algeria");
    
    for(int i = 1; i <= MAX_HIVES; i++) {
        thresholds[i].temp_critical = ALGERIA_TEMP_CRITICAL;
        thresholds[i].temp_warning = ALGERIA_TEMP_WARNING;
        thresholds[i].weight_drop_rate = ALGERIA_SWARMING_DROP_RATE;
        thresholds[i].gas_critical = GAS_CRITICAL;
        thresholds[i].sound_swarming = ALGERIA_SOUND_SWARMING;
        thresholds[i].varroa_vibration = ALGERIA_VARROA_VIBRATION;
    }
    
    ESP_LOGI(TAG, "========================================");
    ESP_LOGI(TAG, "🎖️ نظام خبير متكيف مع المناخ الجزائري");
    ESP_LOGI(TAG, "========================================");
    ESP_LOGI(TAG, "🌍 خط العرض: %.1f°", expert_stats.latitude);
    ESP_LOGI(TAG, "🔥 درجة الحرارة الحرجة: %.0f°C", ALGERIA_TEMP_CRITICAL);
    ESP_LOGI(TAG, "⚠️ درجة الحرارة التحذيرية: %.0f°C", ALGERIA_TEMP_WARNING);
    ESP_LOGI(TAG, "📉 عتبة التطريد: %.1f كجم/ساعة", ALGERIA_SWARMING_DROP_RATE);
    ESP_LOGI(TAG, "🔊 عتبة الصوت للتطريد: %d", ALGERIA_SOUND_SWARMING);
    ESP_LOGI(TAG, "🐝 سلالات النحل: التلي، التحتي، الصحراوي");
    ESP_LOGI(TAG, "========================================");
}

void start(void) { running = true; ESP_LOGI(TAG, "✅ نظام الخبير يعمل"); }
void stop(void) { running = false; ESP_LOGI(TAG, "⏹️ نظام الخبير متوقف"); }
void restart(void) { stop(); init(); start(); }
bool isRunning(void) { return running; }
void setDataReady(void) {}
const char* getLastResult(void) { return last_result; }
HiveState getCurrentState(void) { return current_state; }
void registerStateCallback(StateChangeCallback callback) { state_callback = callback; }
void report_false_positive(int hive_id, AIResult incorrect_result) { expert_stats.false_positives++; }
void set_latitude(float lat) { expert_stats.latitude = lat; }

bool configure_system(const char* brand_name, int wilaya_id, const char* admin_password) { return true; }
bool authenticate(const char* password) { return true; }
const WilayaInfo* get_current_wilaya(void) { return nullptr; }
const char* get_wilaya_name(int wilaya_id) { return "Algeria"; }
// float get_wilaya_max_temp(int wilaya_id) { return ALGERIA_TEMP_CRITICAL; }
bool factory_reset(const char* password) { return false; }
bool is_configured(void) { return true; }

const char* get_expert_statistics(void) {
    static char stats[256];
    snprintf(stats, sizeof(stats),
             "📊 المجموع:%lu | حرج:%lu | تحذير:%lu | خاطئ:%lu | عالق:%lu | خط العرض:%.1f° | %s",
             expert_stats.total, expert_stats.critical, expert_stats.warning,
             expert_stats.false_positives, expert_stats.stuck_events, 
             expert_stats.latitude, expert_stats.region);
    return stats;
}

} // namespace AiEngine
