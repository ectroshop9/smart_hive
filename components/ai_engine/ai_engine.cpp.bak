// ==================== تكييف مع المناخ الجزائري ====================
#define ALGERIA_DEFAULT_LATITUDE     32.0f
#define ALGERIA_TEMP_CRITICAL        43.0f
#define ALGERIA_TEMP_WARNING         38.0f
#define ALGERIA_HUM_CRITICAL         18.0f
#define ALGERIA_HUM_WARNING          25.0f
#define ALGERIA_SWARMING_DROP_RATE   0.6f
#define ALGERIA_SOUND_SWARMING       75
#define ALGERIA_VARROA_VIBRATION     65

// ==================== الحلقة الدائرية ====================
#define HISTORY_SIZE 60

struct CircularBuffer {
    float data[HISTORY_SIZE];
    int head;
    int count;
    
    void init() { head = 0; count = 0; memset(data, 0, sizeof(data)); }
    void push(float v) { data[head] = v; head = (head+1)%HISTORY_SIZE; if(count<HISTORY_SIZE) count++; }
    float get(int offset) const {
        if(offset>=count) return 0;
        int idx = (head-1-offset+HISTORY_SIZE)%HISTORY_SIZE;
        return data[idx];
    }
    float moving_average(int window) const {
        if(window>count) window=count;
        if(window==0) return 0;
        float sum=0;
        for(int i=0;i<window;i++) sum+=get(i);
        return sum/window;
    }
    float trend() const {
        if(count<6) return 0;
        return moving_average(3) - moving_average(6);
    }
    bool is_stuck() const {
        if(count<10) return false;
        float first=get(0);
        for(int i=1;i<10;i++) if(get(i)!=first) return false;
        return true;
    }
};

static CircularBuffer weight_history;
static CircularBuffer temp_history;
static CircularBuffer sound_history;
static CircularBuffer vibration_history;

// ==================== إحصائيات الخبير ====================
static struct {
    uint32_t total;
    uint32_t critical;
    uint32_t warning;
    uint32_t false_positives;
    uint32_t stuck_events;
    float latitude;
    char region[16];
} expert_stats;

// ==================== العتبات المتكيفة ====================
struct AdaptiveThresholds {
    float temp_critical;
    float temp_warning;
    float weight_drop_rate;
    uint8_t gas_critical;
    uint8_t sound_swarming;
    uint8_t varroa_vibration;
};

static AdaptiveThresholds thresholds[MAX_HIVES + 1];

